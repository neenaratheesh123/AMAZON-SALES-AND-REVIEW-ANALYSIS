   "source": [
    "df['rating_count']=pd.to_numeric(\n",
    "    df['rating_count'].str.replace(',', '').str.strip(),errors='coerce'\n",
    ").fillna(0).astype(int)  "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6661dc6e-b67b-4d25-8d86-153037ab4264",
   "metadata": {},
   "source": [
    "* create derived columns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "3235b91b-cb97-490c-a829-98f61921c172",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "df['savings_amount']=df['actual_price'] - df['discounted_price']\n",
    "df['main_category'] = df['category'].str.split('|').str[0]\n",
    "df['sub_category']  = df['category'].str.split('|').str[1]\n",
    "\n",
    "def  rating_band(r):\n",
    "     if    r>=4.5 : return 'Excellent'\n",
    "     elif  r>=4.0 : return  'Good'\n",
    "     elif  r>=3.5 : return  'Average'\n",
    "     else:          return   'poor'\n",
    "df['rating_band'] = df['rating'].apply(rating_band)\n",
    "\n",
    "def discount_tire(d):\n",
    "    if     d>= 70 : return 'High (>=70%)'\n",
    "    elif   d>=40  : return 'Medium(40%-69%)'\n",
    "    else:           return 'Low (<40%)'\n",
    "df['discount_tire']=df['discount_percentage'].apply(discount_tire)\n",
    "\n",
    "def price_cat(P):\n",
    "    if   P<= 299: return 'Budget (<=299)'\n",
    "    elif P<= 999: return  'Mid-range (300-999)'\n",
    "    elif P<=2999: return  'Premium (1000-2999)'\n",
    "    else        : return   'Luxury (3000+)'\n",
    "df['price_category'] = df['discounted_price'].apply(price_cat)    \n",
    "        \n",
    "\n"
   ]
  },
