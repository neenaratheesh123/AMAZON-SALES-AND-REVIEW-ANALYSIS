    "def clean_price(s):\n",
    "    return pd.to_numeric(\n",
    "        s.str.replace('₹', '').str.replace(',', '').str.strip(),\n",
    "        errors='coerce'\n",
    "    )   \n",
    "    "
   ]
  },
